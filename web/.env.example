# Dev: Vite proxies /tasks → localhost:8080, no env needed.
# Set this only when deploying frontend separately from Ktor.
# VITE_API_URL=http://localhost:8080

# Feature toggles — set to 'false' to disable. All enabled by default.
# VITE_FEATURE_PRIORITY=false
# VITE_FEATURE_DEADLINE=false
# VITE_FEATURE_DESCRIPTION=false
# VITE_FEATURE_RECORDS=false
# VITE_FEATURE_GROUPS=false
# VITE_FEATURE_SPACES=false
# VITE_FEATURE_PROFILE=false
