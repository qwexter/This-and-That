meta {
  name: Create group
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/groups
  body: json
  auth: none
}

headers {
  X-User-Id: {{userId}}
}

body:json {
  {
    "title": "My group"
  }
}

docs {
  spaceId is optional. Omit to use the caller's private space.
  Example with explicit space: { "title": "Sprint 1", "spaceId": "some-space-id" }
}
